# Create a bot with @BotFather, then paste its token here.
BOT_TOKEN=123456789:replace_with_your_bot_token

# Create a key at https://openrouter.ai/keys.
OPENROUTER_API_KEY=sk-or-v1-replace_with_your_openrouter_key

# Requested model. Change only if you intentionally want another model.
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional attribution sent to OpenRouter.
# OPENROUTER_SITE_URL=https://example.com

# Optional default for /quiz and /fulltest command fallbacks.
# Quick Quiz always uses 10 questions from one random unit.
QUESTION_COUNT=10

# Optional location for the shared exhaustion-based question cache.
# QUESTION_CACHE_DB=C:\path\to\question_cache.sqlite3

# Telegram numeric user IDs allowed to use /dashboard. Separate multiple IDs with commas.
# ADMIN_USER_IDS=123456789

# Optional: load unit Markdown files from another directory.
# UNITS_DIR=C:\path\to\unit-files
